          "path": "lib/styles.ts",
          "type": "registry:lib",
          "target": "lib/styles.ts"
        }
      ]
    },
    {
      "name": "use-rough",
      "type": "registry:hook",
      "title": "useRough",
      "description": "Shared Rough.js SVG hook for Crumble primitives.",
      "dependencies": ["roughjs"],
      "registryDependencies": ["rough-lib"],
      "files": [
