{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "crumble",
  "homepage": "https://crumble.dev",
  "items": [
    {
      "name": "rough-lib",
      "type": "registry:lib",
      "title": "Rough Theme Config",
      "description": "Core Rough.js theme presets and global config for Crumble.",
      "dependencies": ["roughjs"],
      "files": [
        {
          "path": "lib/rough.ts",
          "type": "registry:lib",
          "target": "lib/rough.ts"
        }
      ]
    },
    {
      "name": "styles-lib",
      "type": "registry:lib",
      "title": "Crumble Styles",
